# Optional for core training (the committed seed bank loads offline).
# Required only for the AI features: /api/generate (twins), /api/coach
# (post-mortem), /api/parse-report (score-report import), pnpm seed --api.
ANTHROPIC_API_KEY=

# Optional. Defaults to claude-sonnet-5.
ANTHROPIC_MODEL=

# Optional locally, REQUIRED for hosted deployments (see DEPLOY.md).
# When set, every page and API route sits behind a login screen.
SITE_PASSWORD=

# Hosted database (optional). Unset = local SQLite file at ./data/q86.db.
# Set both to point the app, `pnpm db:push`, and `pnpm seed` at a Turso
# database instead — required for Vercel (see DEPLOY.md).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
