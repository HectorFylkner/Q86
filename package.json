{
  "name": "q86",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Q86 — personal GMAT Focus quant training platform",
  "engines": {
    "node": ">=22.6"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "db:push": "node -e \"require('fs').mkdirSync('data',{recursive:true})\" && drizzle-kit push",
    "seed": "node --experimental-strip-types scripts/seed.ts",
    "backup": "node --experimental-strip-types scripts/backup.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.0",
    "@libsql/client": "^0.17.4",
    "@phosphor-icons/react": "^2.1.10",
    "ai": "^5.0.0",
    "browser-image-compression": "^2.0.2",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.0.0",
    "katex": "^0.16.21",
    "mathjs": "^15.2.0",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/katex": "^0.16.7",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.31.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "overrides": {
      "@esbuild-kit/core-utils>esbuild": "^0.25.0",
      "postcss": "^8.5.10"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  }
}
